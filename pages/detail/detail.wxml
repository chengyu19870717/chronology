<view class="page detail-page" wx:if="{{record}}">
  <view class="detail-hero">
    <view class="date-pill">{{record.dateText}}</view>
    <view class="detail-title">{{record.name}}</view>
    <view class="detail-summary">{{record.summary}}</view>
    <view class="detail-actions">
      <button class="primary-button" bindtap="toggleFavorite">{{isFavorite ? '★ 已收藏' : '☆ 收藏'}}</button>
      <button class="ghost-button" bindtap="copySummary">复制摘要</button>
    </view>
  </view>

  <view class="info-grid">
    <view wx:if="{{record.capital}}" class="info-cell">
      <text class="info-label">都城</text>
      <text class="info-value">{{record.capital}}</text>
    </view>
    <view wx:if="{{record.founder}}" class="info-cell">
      <text class="info-label">建立者</text>
      <text class="info-value">{{record.founder}}</text>
    </view>
    <view class="info-cell">
      <text class="info-label">类型</text>
      <text class="info-value">{{typeLabel}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">速记要点</view>
    <view wx:for="{{record.points}}" wx:key="*this" class="point-row">
      <view class="point-dot"></view>
      <text class="point-text">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{record.figures && record.figures.length}}" class="section">
    <view class="section-title">关联人物</view>
    <view class="tag-row">
      <text wx:for="{{record.figures}}" wx:key="*this" class="tag person-tag">{{item}}</text>
    </view>
  </view>

  <view wx:if="{{record.tags && record.tags.length}}" class="section">
    <view class="section-title">关键词</view>
    <view class="tag-row">
      <text wx:for="{{record.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<view class="page missing-page" wx:else>
  <view class="missing-title">条目不存在</view>
  <view class="missing-copy">可能是数据已调整，请返回列表重新选择。</view>
  <button class="primary-button missing-button" bindtap="goBack">返回</button>
</view>
