.event-page {
  padding-bottom: 40rpx;
}

.event-hero {
  padding: 28rpx 24rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid var(--line);
}

.date-pill {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 13rpx;
  border-radius: 8rpx;
  background: var(--cinnabar-soft);
  color: var(--cinnabar);
  font-size: 22rpx;
  font-weight: 800;
}

.event-title {
  margin-top: 14rpx;
  color: var(--night);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
}

.event-period {
  margin-top: 7rpx;
  color: var(--bronze);
  font-size: 23rpx;
  font-weight: 800;
}

.event-summary,
.flow-text,
.person-summary,
.debate-text,
.empty-note {
  color: #3F4A4E;
  font-size: 26rpx;
  line-height: 1.65;
}

.event-summary {
  margin-top: 16rpx;
}

.label-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.tab-row {
  position: sticky;
  z-index: 20;
  top: 0;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  background: rgba(255, 255, 255, 0.98);
  border-bottom: 2rpx solid var(--line);
  box-shadow: 0 5rpx 14rpx rgba(23, 42, 47, 0.06);
}

.tab-button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 800;
}

.tab-button.is-active {
  color: var(--jade);
}

.tab-button.is-active::after {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 0;
  height: 5rpx;
  border-radius: 5rpx 5rpx 0 0;
  background: var(--jade);
  content: "";
}

.section {
  margin-top: 14rpx;
  padding: 26rpx 24rpx 30rpx;
  background: #FFFFFF;
  border-top: 2rpx solid var(--line);
  border-bottom: 2rpx solid var(--line);
}

.section-title {
  color: var(--night);
  font-size: 31rpx;
  font-weight: 900;
}

.flow-card {
  position: relative;
  display: flex;
  gap: 16rpx;
  margin-top: 0;
  padding: 22rpx 0 22rpx;
  border-bottom: 2rpx solid var(--line);
}

.flow-card:first-of-type {
  margin-top: 12rpx;
}

.flow-card::before {
  position: absolute;
  left: 29rpx;
  top: 64rpx;
  bottom: -2rpx;
  width: 2rpx;
  background: var(--line-strong);
  content: "";
}

.flow-card:last-child {
  border-bottom: 0;
}

.flow-card:last-child::before {
  display: none;
}

.flow-index {
  position: relative;
  z-index: 2;
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  border: 2rpx solid #CFE0DC;
  border-radius: 50%;
  background: var(--jade-soft);
  color: var(--jade);
  font-size: 20rpx;
  font-weight: 900;
}

.flow-main {
  flex: 1;
  min-width: 0;
}

.flow-card.is-impact .flow-index {
  border-color: #DAB8B3;
  background: var(--cinnabar-soft);
  color: var(--cinnabar);
}

.flow-label {
  color: var(--bronze);
  font-size: 23rpx;
  font-weight: 900;
}

.flow-text {
  margin-top: 7rpx;
}

.person-card,
.debate-card {
  position: relative;
  margin-top: 16rpx;
  padding: 20rpx;
  border: 2rpx solid var(--line);
  border-radius: 14rpx;
  background: #FFFFFF;
}

.person-card {
  min-height: 108rpx;
  padding-left: 102rpx;
}

.person-avatar {
  position: absolute;
  left: 20rpx;
  top: 22rpx;
  width: 62rpx;
  height: 62rpx;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  background: var(--soft);
  overflow: hidden;
}

.person-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cinnabar);
  font-size: 27rpx;
  font-weight: 900;
}

.person-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.person-name,
.debate-title {
  color: var(--night);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.person-meta,
.cross-text {
  margin-top: 7rpx;
  color: var(--bronze);
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.45;
}

.person-summary {
  margin-top: 10rpx;
}

.person-card .person-summary {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.arrow-mark {
  margin-left: 14rpx;
  color: var(--jade);
  font-size: 40rpx;
  line-height: 1;
}

.dispute-tabs {
  margin-top: 16rpx;
  white-space: nowrap;
}

.dispute-row {
  display: inline-flex;
  gap: 9rpx;
  padding-bottom: 2rpx;
}

.dispute-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  padding: 0 17rpx;
  border: 2rpx solid var(--line-strong);
  border-radius: 10rpx;
  background: #FFFFFF;
  color: var(--bronze);
  font-size: 23rpx;
  font-weight: 800;
}

.dispute-button.is-active {
  border-color: #DAB8B3;
  background: var(--cinnabar-soft);
  color: var(--cinnabar);
}

.debate-card {
  border-left: 6rpx solid var(--cinnabar);
}

.debate-title {
  margin-bottom: 9rpx;
}

.empty-note {
  margin-top: 18rpx;
  padding: 26rpx 20rpx;
  border: 2rpx dashed var(--line-strong);
  border-radius: 14rpx;
  background: var(--soft);
  text-align: center;
}

.missing-page {
  display: flex;
  min-height: 100vh;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 24rpx;
  text-align: center;
}

.missing-title {
  color: var(--night);
  font-size: 34rpx;
  font-weight: 900;
}

.missing-copy {
  margin-top: 12rpx;
  color: var(--muted);
  font-size: 25rpx;
}

.missing-button {
  width: 220rpx;
  margin-top: 26rpx;
}
