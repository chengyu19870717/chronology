<view wx:if="{{person}}" class="page detail-page">
  <view class="hero person-hero">
    <view class="hero-row">
      <image wx:if="{{person.hasAvatar && !avatarLoadFailed}}" class="portrait-image" src="{{person.avatarPath}}" mode="aspectFill" binderror="onAvatarError" />
      <view wx:else class="portrait-fallback">
        <text class="portrait-initial">{{person.avatarInitial}}</text>
        <text class="portrait-mark">史</text>
      </view>
      <view class="hero-main">
        <view class="date-pill">{{person.lifeText}}</view>
        <view class="hero-title">{{person.name}}</view>
        <view class="hero-subtitle">{{person.categoryText}}</view>
      </view>
    </view>
    <view class="hero-summary">{{person.summary}}</view>
    <view class="tag-row">
      <view
        wx:for="{{person.categories}}"
        wx:key="*this"
        class="tag person-glossary-tag"
        data-label="{{item}}"
        role="button"
        aria-label="查看{{item}}标签含义"
        catchtap="showTagInfo"
        hover-class="button-hover"
        hover-stay-time="80"
      >
        <text>{{item}}</text>
        <text class="person-tag-info-dot">i</text>
      </view>
    </view>
    <view class="cross-box">
      <text class="cross-label">所属朝代</text>
      <text class="cross-value">{{person.crossText}}</text>
      <text class="cross-note">{{person.activePeriodText}}</text>
    </view>
  </view>

  <view class="tab-row">
    <view
      wx:for="{{tabs}}"
      wx:key="id"
      class="tab-button {{activeTab === item.id ? 'is-active' : ''}}"
      data-tab-id="{{item.id}}"
      role="tab"
      aria-label="查看{{item.name}}"
      aria-selected="{{activeTab === item.id}}"
      bindtap="switchTab"
    >{{item.name}}</view>
  </view>

  <view wx:if="{{activeTab === 'profile'}}" class="section">
    <view class="section-title">基础档案</view>
    <view class="info-block"><view class="info-label">家世与时代背景</view><view class="body-text">{{person.background}}</view></view>
    <view class="info-block"><view class="info-label">早期经历与材料边界</view><view class="body-text">{{person.childhood}}</view></view>
    <view class="info-block"><view class="info-label">性格特征</view><view class="body-text">{{person.personality}}</view></view>
    <view class="info-block"><view class="info-label">政策与行动倾向</view><view class="body-text">{{person.policyInclination}}</view></view>
    <view class="info-block"><view class="info-label">社会贡献</view><view class="body-text">{{person.socialContribution}}</view></view>
    <view class="info-block"><view class="info-label">历史影响</view><view class="body-text">{{person.impactSummary}}</view></view>
  </view>

  <view wx:elif="{{activeTab === 'resume'}}" class="section">
    <view class="section-title">简历式履历 · {{resume.length}}</view>
    <view wx:for="{{resume}}" wx:key="timeText" class="resume-card">
      <view class="resume-time">{{item.timeText}}</view>
      <view class="card-title">{{item.periodLabel}} · {{item.title}}</view>
      <view class="field-row"><text class="field-label">名义职责</text><text class="field-value">{{item.nominalDuty}}</text></view>
      <view class="field-row is-strong"><text class="field-label">管辖权限</text><text class="field-value">{{item.authorityScope}}</text></view>
      <view class="field-row"><text class="field-label">实际影响力</text><text class="field-value">{{item.actualInfluence}}</text></view>
      <view class="field-row"><text class="field-label">职能近似</text><text class="field-value">{{item.modernEquivalent}}</text></view>
      <view class="card-impact">{{item.impact}}</view>
    </view>
  </view>

  <view wx:elif="{{activeTab === 'relations'}}" class="section">
    <view class="section-title">人物关系 · {{relationships.length}}</view>
    <view wx:for="{{relationships}}" wx:key="otherId" class="link-card" data-id="{{item.otherId}}" bindtap="goPerson">
      <view class="link-top">
        <image wx:if="{{item.other.hasAvatar}}" class="mini-avatar" src="{{item.other.avatarPath}}" mode="aspectFill" />
        <view wx:else class="mini-avatar">{{item.other.avatarInitial}}</view>
        <view class="link-main"><view class="card-title">{{person.name}} ↔ {{item.other.name}}</view><view class="card-meta">{{item.type}}</view></view>
        <view class="arrow">›</view>
      </view>
      <view class="body-text">{{item.summary}}</view>
      <view wx:if="{{item.eventText}}" class="link-note">关联线索：{{item.eventText}}</view>
    </view>
    <view wx:if="{{!relationships.length}}" class="empty-note">暂无可核对的人物关系资料。</view>
  </view>

  <view wx:elif="{{activeTab === 'events'}}" class="section">
    <view class="section-title">相关事件 · {{relatedEvents.length}}</view>
    <view wx:for="{{relatedEvents}}" wx:key="id" class="link-card" data-id="{{item.id}}" bindtap="goEvent">
      <view class="card-meta">{{item.dateText}} · {{item.periodLabel}}</view>
      <view class="card-title">{{item.name}}</view>
      <view class="body-text">{{item.summary}}</view>
      <view class="link-note">{{item.tagText}}</view>
    </view>
  </view>

  <view wx:else class="section">
    <view class="section-title">不同认知观点</view>
    <scroll-view class="dispute-tabs" scroll-x="true" show-scrollbar="false">
      <view class="dispute-row"><button wx:for="{{person.disputeTabs}}" wx:key="title" class="dispute-button {{index === activeDisputeIndex ? 'is-active' : ''}}" data-index="{{index}}" catchtap="switchDispute">{{item.title}}</button></view>
    </scroll-view>
    <view class="debate-card"><view class="card-title">{{activeDispute.title}}</view><view class="body-text">{{activeDispute.body}}</view></view>
  </view>

  <view
    wx:if="{{tagDialogVisible && activeTagInfo}}"
    class="person-tag-dialog-mask"
    catchtouchmove="preventTouchMove"
    bindtap="closeTagInfo"
  >
    <view class="person-tag-dialog-sheet" catchtap="stopTagDialogTap">
      <view class="person-tag-dialog-handle"></view>
      <view class="person-tag-dialog-head">
        <view class="person-tag-dialog-title">{{activeTagInfo.label}}</view>
        <button class="person-tag-dialog-close" aria-label="关闭标签说明" catchtap="closeTagInfo">×</button>
      </view>
      <view class="person-tag-dialog-meta">{{activeTagInfo.category}} · {{activeTagInfo.personName}}</view>
      <view class="person-tag-dialog-section">
        <view class="person-tag-dialog-label">基本含义</view>
        <view class="person-tag-dialog-copy">{{activeTagInfo.definition}}</view>
      </view>
      <view class="person-tag-dialog-section">
        <view class="person-tag-dialog-label">本人物标注重点</view>
        <view class="person-tag-dialog-copy">{{activeTagInfo.context}}</view>
      </view>
      <view class="person-tag-dialog-note">{{activeTagInfo.note}}</view>
    </view>
  </view>

  <view class="safe-bottom"></view>
  <button wx:if="{{showBackTop}}" class="back-top-button" catchtap="scrollToTop">↑</button>
</view>

<view wx:else class="page missing-page">
  <view class="hero-title">人物不存在</view>
  <view class="body-text">请返回首页重新选择。</view>
  <button class="primary-button missing-button" bindtap="goBack">返回</button>
</view>
