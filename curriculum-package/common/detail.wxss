.detail-page {
  padding: 18rpx 20rpx 40rpx;
}

.hero,
.section {
  border: 2rpx solid var(--line);
  border-radius: 16rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx var(--shadow);
}

.hero {
  padding: 24rpx;
  border-top: 8rpx solid var(--cinnabar);
}

.hero-row,
.link-top,
.field-row,
.flow-card {
  display: flex;
  align-items: flex-start;
}

.portrait-fallback,
.portrait-image,
.mini-avatar {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  background: var(--cinnabar-soft);
  color: var(--cinnabar);
  font-weight: 900;
}

.portrait-fallback {
  position: relative;
  width: 142rpx;
  height: 168rpx;
  border: 2rpx solid #D9B9B4;
  border-radius: 12rpx;
}

.portrait-image {
  flex: 0 0 auto;
  width: 142rpx;
  height: 168rpx;
  border: 2rpx solid #D9B9B4;
  border-radius: 12rpx;
  background: var(--soft);
  object-fit: cover;
}

.portrait-initial {
  font-size: 64rpx;
}

.portrait-mark {
  position: absolute;
  right: 10rpx;
  bottom: 8rpx;
  color: var(--bronze);
  font-size: 20rpx;
}

.hero-main,
.link-main,
.flow-main {
  flex: 1;
  min-width: 0;
}

.hero-main {
  padding-left: 22rpx;
}

.date-pill {
  display: inline-flex;
  max-width: 100%;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: var(--bronze-soft);
  color: var(--bronze);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.4;
}

.hero-title {
  margin-top: 12rpx;
  color: var(--night);
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.24;
  word-break: break-all;
}

.hero-subtitle,
.card-meta,
.link-note,
.resume-time {
  margin-top: 8rpx;
  color: var(--bronze);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.5;
}

.hero-summary,
.body-text,
.field-value,
.card-impact {
  color: #3F4A4E;
  font-size: 25rpx;
  line-height: 1.7;
}

.hero-summary {
  margin-top: 20rpx;
}

.tag-row {
  display: flex;
  align-items: center;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.cross-box {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 6rpx 14rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 10rpx;
  background: var(--jade-soft);
}

.cross-label {
  color: var(--jade);
  font-size: 22rpx;
  font-weight: 900;
}

.cross-value,
.cross-note {
  color: var(--ink);
  font-size: 23rpx;
  line-height: 1.45;
}

.cross-note {
  grid-column: 1 / -1;
  color: var(--muted);
}

.tab-row {
  position: sticky;
  z-index: 20;
  top: 0;
  display: flex;
  margin-top: 16rpx;
  padding: 6rpx;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.98);
}

.tab-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1 1 0;
  width: 0;
  height: 58rpx;
  min-height: 58rpx;
  border-radius: 8rpx;
  color: var(--muted);
  font-size: 23rpx;
  font-weight: 800;
}

.tab-button.is-active {
  background: var(--jade);
  color: #FFFFFF;
}

.section {
  margin-top: 16rpx;
  padding: 22rpx;
}

.section-title {
  color: var(--night);
  font-size: 30rpx;
  font-weight: 900;
}

.info-block,
.resume-card,
.link-card,
.debate-card,
.flow-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 2rpx solid var(--line);
  border-radius: 12rpx;
  background: var(--soft);
}

.info-label,
.field-label {
  color: var(--jade);
  font-size: 22rpx;
  font-weight: 900;
}

.info-block .body-text {
  margin-top: 8rpx;
}

.card-title {
  margin-top: 6rpx;
  color: var(--night);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.45;
}

.field-row {
  gap: 14rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid var(--line);
}

.field-row.is-strong {
  margin-right: -8rpx;
  margin-left: -8rpx;
  padding: 14rpx 8rpx 0;
  border-top-color: #BFD3CE;
  background: var(--jade-soft);
}

.field-label {
  flex: 0 0 112rpx;
}

.field-value {
  flex: 1;
}

.card-impact {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 2rpx dashed var(--line-strong);
}

.mini-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  object-fit: cover;
  overflow: hidden;
}

.link-main {
  padding-left: 14rpx;
}

.link-top + .body-text,
.link-card > .body-text {
  margin-top: 12rpx;
}

.arrow {
  color: var(--jade);
  font-size: 40rpx;
}

.dispute-tabs {
  margin-top: 16rpx;
  white-space: nowrap;
}

.dispute-row {
  display: inline-flex;
  gap: 10rpx;
}

.dispute-button {
  min-height: 54rpx;
  padding: 0 18rpx;
  border: 2rpx solid var(--line-strong);
  border-radius: 9rpx;
  color: var(--bronze);
  font-size: 23rpx;
  font-weight: 800;
}

.dispute-button.is-active {
  border-color: #D9B9B4;
  background: var(--cinnabar-soft);
  color: var(--cinnabar);
}

.flow-card {
  gap: 16rpx;
}

.flow-card.is-impact {
  border-left: 6rpx solid var(--cinnabar);
}

.flow-index {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--jade);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 900;
}

.flow-main .body-text {
  margin-top: 8rpx;
}

.empty-note {
  margin-top: 18rpx;
  padding: 26rpx;
  border: 2rpx dashed var(--line-strong);
  border-radius: 12rpx;
  color: var(--muted);
  text-align: center;
}

.missing-page {
  display: flex;
  min-height: 100vh;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  padding: 30rpx;
  text-align: center;
}

.missing-button {
  width: 220rpx;
  margin-top: 24rpx;
}
